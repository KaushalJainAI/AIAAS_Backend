# AIAAS backend environment for EC2-hosted PostgreSQL
# Copy to `Backend/.env` on the host where AIAAS runs, then fill in the blanks.

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

SECRET_KEY=change-me
DEBUG=False
CREDENTIAL_ENCRYPTION_KEY=change-me

TELEGRAM_WEBHOOK_URL=

# Recommended for EC2 Postgres via PgBouncer
# Example:
# DATABASE_URL=postgresql://my_project_user:strong-password@<EC2_PUBLIC_IP>:6432/my_project?sslmode=require
DATABASE_URL=

# Fallback explicit database fields
DB_ENGINE=postgresql
DB_CONN_MAX_AGE=0
DB_SSLMODE=require
POSTGRES_HOST=
POSTGRES_PORT=6432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# App networking/runtime
PUBLIC_URL=http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
USE_REDIS_CHANNEL_LAYER=True
RUN_WORKFLOWS_ASYNC=False

# Optional model/provider keys
OPEN_ROUTER_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=
TAVILY_API_KEY=
LLM_API_KEY=

# Notes:
# 1. Use port 6432 with DB_CONN_MAX_AGE=0 when connecting through PgBouncer.
# 2. Use port 5432 with DB_CONN_MAX_AGE=60 when connecting directly to PostgreSQL.
# 3. If you use DATABASE_URL, it takes precedence over POSTGRES_* fields.
